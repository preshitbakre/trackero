    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.21",
    "@swc/core": "^1.15.33",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
