# ============================================
# TRACKERO CONFIGURATION
# ============================================

# --- Server ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# In Docker: use trackero_app (restricted DML-only user).
# The migrate service uses trackero_admin (full DDL) via compose overrides.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=trackero_app
DATABASE_PASSWORD=trackero_app_secret
DATABASE_NAME=trackero

# --- Auth ---
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- File Storage (MinIO / S3) ---
STORAGE_DRIVER=s3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=trackero-files
MINIO_USE_SSL=false
# Public URL for presigned URLs (set when MINIO_ENDPOINT is an internal hostname, e.g. Docker)
# MINIO_PUBLIC_URL=http://localhost:9000
PRESIGNED_URL_EXPIRY=1800
MAX_UPLOAD_SIZE_MB=10

# --- Email (SMTP) ---
# Leave SMTP_HOST empty to disable emails (they'll log to console instead)
# For Gmail: set SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@trackero.dev

# --- Swagger ---
# In non-production, Swagger is always enabled.
# In production, set to true to expose /api/docs.
SWAGGER_ENABLED=false

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=30
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_LIMIT=5
