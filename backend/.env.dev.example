# ============================================
# TRACKERO CONFIGURATION — Local Development
# ============================================
# For running the backend directly on your machine (npm run start:dev).
# Requires a local PostgreSQL and optionally a local MinIO instance.
# For Docker, use .env.example instead.

# --- Server ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=trackero

# --- Auth ---
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- File Storage (MinIO / S3) ---
STORAGE_DRIVER=s3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=trackero-files
MINIO_USE_SSL=false
PRESIGNED_URL_EXPIRY=1800
MAX_UPLOAD_SIZE_MB=10

# --- Email (SMTP) ---
# Leave SMTP_HOST empty to disable emails (they'll log to console instead)
# For Gmail: set SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@trackero.dev

# --- Swagger ---
# Always enabled in development regardless of this value
SWAGGER_ENABLED=false

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=30
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_LIMIT=5
