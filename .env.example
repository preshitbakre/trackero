# ============================================
# TRACKERO CONFIGURATION
# ============================================

# --- Server ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=trackero
DATABASE_PASSWORD=trackero_secret
DATABASE_NAME=trackero

# --- Auth ---
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- File Storage (MinIO / S3) ---
STORAGE_DRIVER=s3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=trackero-files
MINIO_USE_SSL=false
PRESIGNED_URL_EXPIRY=1800
MAX_UPLOAD_SIZE_MB=10

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@trackero.dev
# If SMTP is not configured, email features are disabled (logged to console)

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=30
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_LIMIT=5
